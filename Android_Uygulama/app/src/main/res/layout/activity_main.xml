<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Kamera on izleme -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/cardSonuc"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Galeri resmi (kamera yerine gosterilir, varsayilan gizli) -->
    <ImageView
        android:id="@+id/ivGaleriResim"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:scaleType="fitCenter"
        android:background="#000000"
        app:layout_constraintTop_toTopOf="@id/previewView"
        app:layout_constraintBottom_toBottomOf="@id/previewView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Segmentasyon maskesi (kirmizi hastalik overlay) -->
    <com.bitirme.yaprakanaliz.OverlayView
        android:id="@+id/overlayView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="@id/previewView"
        app:layout_constraintBottom_toBottomOf="@id/previewView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- NIR overlay (varsayilan gizli, NIR moduna geçince gorunur) -->
    <com.bitirme.yaprakanaliz.OverlayView
        android:id="@+id/nirOverlayView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/previewView"
        app:layout_constraintBottom_toBottomOf="@id/previewView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Alt bilgi karti -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardSonuc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#CC1B1B1B"
        app:cardCornerRadius="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Durum yazisi -->
            <TextView
                android:id="@+id/tvDurum"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Yapragi kameraya tutun"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center" />

            <!-- Analiz ilerleme cubugu -->
            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="6dp"
                android:indeterminate="true"
                android:indeterminateTint="#1E88E5"
                android:visibility="gone" />

            <!-- Hastalik yuzdesi -->
            <TextView
                android:id="@+id/tvSonuc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hastalik: -%"
                android:textColor="#AAAAAA"
                android:textSize="15sp"
                android:gravity="center"
                android:layout_marginTop="4dp" />

            <!-- FPS ve cıkarım süresi -->
            <TextView
                android:id="@+id/tvPerformans"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#555555"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_marginTop="2dp"
                android:visibility="gone" />

            <!-- Mod secme butonlari (Segmentasyon / NIR) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">

                <Button
                    android:id="@+id/btnModSeg"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:text="Segmentasyon"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#2E7D32"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/btnModNir"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:text="NIR Haritasi"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#555555"
                    android:layout_marginStart="4dp" />

            </LinearLayout>

            <!-- Galeriden test butonu -->
            <Button
                android:id="@+id/btnGaleriden"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="Galeriden Test Et"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#00695C"
                android:layout_marginTop="8dp" />

            <!-- Analiz butonu -->
            <Button
                android:id="@+id/btnAnalizBaslat"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Analizi Baslat"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1565C0"
                android:layout_marginTop="8dp" />

            <!-- Kaydet ve Gecmis butonlari -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp">

                <Button
                    android:id="@+id/btnKaydet"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="44dp"
                    android:text="Kaydet"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#E65100"
                    android:enabled="false"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/btnGecmis"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="44dp"
                    android:text="Gecmis"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#37474F"
                    android:layout_marginStart="4dp" />

            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
